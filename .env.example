# ===== 数据库 =====
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_USER=audiobook
POSTGRES_PASSWORD=audiobook_secret
POSTGRES_DB=audiobook

# ===== Redis =====
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# ===== Celery =====
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# ===== JWT 密钥 =====
JWT_SECRET_KEY=change-me-to-a-real-secret-key-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ===== 本地存储 =====
STORAGE_TYPE=local
LOCAL_STORAGE_ROOT=/app/storage
LOCAL_STORAGE_BASE_URL=http://localhost:8000/storage

# ===== 后端服务 =====
PUBLIC_BASE_URL=http://localhost:8002
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# ===== CORS =====
CORS_ORIGINS=http://localhost:8000,http://localhost:3000

# ===== TTS / abogen =====
# Worker 会优先调用 abogen 生成真实音频。部署环境需安装 abogen：
# https://github.com/denizsafak/abogen
TTS_ENGINE=abogen
ABOGEN_COMMAND=abogen
# 如果你的 abogen CLI 参数不同，设置模板覆盖默认尝试：
# ABOGEN_COMMAND_TEMPLATE=abogen --input {input} --output {output}
ABOGEN_COMMAND_TEMPLATE=
ABOGEN_EXTRA_ARGS=
ABOGEN_VOICE=
ABOGEN_TIMEOUT=3600

# ===== 公开访问地址（移动端连接后端用） =====
# PUBLIC_BASE_URL=http://192.168.0.104:8002

# ===== TTS =====
# TTS_VOICE=zh-CN-YunxiNeural
